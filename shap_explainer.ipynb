    "import shap\n",
    "import pickle\n",
    "\n",
    "rf_model = pickle.load(open(\"model/rf_model.pkl\", \"rb\"))\n",
    "explainer = shap.TreeExplainer(rf_model)\n",
    "\n",
    "def get_shap_values(features_array):\n",
    "    shap_values = explainer.shap_values(features_array)\n",
    "    return shap_values"
   ]
